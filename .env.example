# ─── IDS Configuration ────────────────────────────────────────────────────
ENV=development

# ─── Capture ──────────────────────────────────────────────────────────────
# IMPORTANT: Keep CAPTURE_MODE=pcap on Windows unless running as Administrator
# live  = sniff real packets (requires admin + Npcap installed)
# pcap  = replay PCAP file  (no admin, works out of the box)
CAPTURE_MODE=pcap
PCAP_FILE=data/pcap/test.pcap
CAPTURE_INTERFACE=Ethernet

# ─── Detection Thresholds ─────────────────────────────────────────────────
ANOMALY_THRESHOLD=0.7
RF_CONFIDENCE_THRESHOLD=0.8
AUTOENCODER_THRESHOLD=0.85
ENSEMBLE_VOTE_THRESHOLD=2

# ─── HIDS ─────────────────────────────────────────────────────────────────
# Windows: point to local log files, not Linux paths
HIDS_LOG_PATHS=logs/ids.log
HIDS_WATCH_DIRS=data,src
BASELINE_FILE=data/baselines/file_hashes.json
HIDS_POLL_INTERVAL=30

# ─── Alerts ───────────────────────────────────────────────────────────────
ALERT_DEDUP_WINDOW=60
ALERT_RATE_LIMIT=100
DB_PATH=db/ids.sqlite

# ─── Email (optional) ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=
EMAIL_MIN_SEVERITY=HIGH

# ─── Slack (optional) ─────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
SLACK_MIN_SEVERITY=MEDIUM

# ─── ML Models ────────────────────────────────────────────────────────────
MODEL_DIR=src/ml/models
IF_MODEL_PATH=src/ml/models/isolation_forest.joblib
RF_MODEL_PATH=src/ml/models/random_forest.joblib
AE_MODEL_PATH=src/ml/models/autoencoder.pt
SCALER_PATH=src/ml/models/scaler.joblib

# ─── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/ids.log
